+<script>
+function toggleOverrideTimeFields() {
+  const mode = document.getElementById('override_mode');
+  const startWrap = document.getElementById('override_start_wrap');
+  const endWrap = document.getElementById('override_end_wrap');
+
+  if (!mode || !startWrap || !endWrap) return;
+
+  const showTimes = mode.value === 'block_range' || mode.value === 'custom_slots';
+  startWrap.style.display = showTimes ? 'block' : 'none';
+  endWrap.style.display = showTimes ? 'block' : 'none';
+}
+
+document.addEventListener('DOMContentLoaded', toggleOverrideTimeFields);
+</script>
+{% endif %}
+
+{% endblock %}
